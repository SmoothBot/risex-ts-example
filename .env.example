# Your main wallet private key (the account that holds funds)
# note: Creating the signer key will be possible in on the RISEx web app soon. 
ACCOUNT_PRIVATE_KEY=0x...

# Signer private key (session key for trading). If not provided, one will be generated.
SIGNER_PRIVATE_KEY=0x...

# API base URL (default: testnet)
API_URL=https://api.testnet.rise.trade
